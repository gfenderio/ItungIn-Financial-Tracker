rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Per-User Data: Only the authenticated user can access their own data ──
    // This covers all sub-collections: transactions, debts, budgets, savings,
    // subscriptions, accounts, notifications, and nested settings.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── Block everything else ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
